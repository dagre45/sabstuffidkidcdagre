-- AUTO LEFT/RIGHT ROUTE (Chiron style - 4 waypoints, speed switches on carry)
local APPROACH_SPEED = 59
local CARRY_SPEED = 29

local stealPath_Right = {
    Vector3.new(-470.6, -5.9, 34.4),   -- approach
    Vector3.new(-484.2, -3.9, 21.4),   -- steal spot
    Vector3.new(-475.6, -5.8, 29.3),   -- back out
    Vector3.new(-473.4, -5.9, 111),    -- return to base
}
local stealPath_Left = {
    Vector3.new(-474.7, -5.9, 91.0),   -- approach
    Vector3.new(-483.4, -3.9, 97.3),   -- steal spot
    Vector3.new(-474.7, -5.9, 91.0),   -- back out
    Vector3.new(-476.1, -5.5, 25.4),   -- return to base
}

local stealPathActive = false

local function doAutoRoute(side)
    local path = side=="Left" and stealPath_Left or stealPath_Right
    stealPathActive = true

    local conn
    local phase = 1

    conn = Run.Heartbeat:Connect(function()
        if not stealPathActive then
            if conn then conn:Disconnect() end
            return
        end
        if (side=="Left" and not S.AutoLeft) or (side=="Right" and not S.AutoRight) then
            stealPathActive = false
            if conn then conn:Disconnect() end
            local h=getHRP() if h then h.AssemblyLinearVelocity=Vector3.new(0,h.AssemblyLinearVelocity.Y,0) end
            return
        end

        local c=me.Character if not c then return end
        local rp=c:FindFirstChild("HumanoidRootPart")
        local hum2=c:FindFirstChildOfClass("Humanoid")
        if not rp or not hum2 then return end

        local target = path[phase]
        -- Speed: fast for approach (1-2), slow carry speed for return (3-4)
        local spd = phase <= 2 and APPROACH_SPEED or CARRY_SPEED

        local tgt = Vector3.new(target.X, rp.Position.Y, target.Z)
        local dist = (tgt - rp.Position).Magnitude

        if dist < 1.5 then
            if phase >= #path then
                -- Done - stop and reset
                stealPathActive = false
                S.AutoLeft = false
                S.AutoRight = false
                rp.AssemblyLinearVelocity = Vector3.new(0, rp.AssemblyLinearVelocity.Y, 0)
                if conn then conn:Disconnect() end
                return
            else
                phase = phase + 1
                if phase == 3 then task.wait(0.2) end -- brief pause after steal
            end
        else
            local dir = (target - rp.Position)
            local mv = Vector3.new(dir.X, 0, dir.Z).Unit
            hum2:Move(mv, false)
            rp.AssemblyLinearVelocity = Vector3.new(mv.X*spd, rp.AssemblyLinearVelocity.Y, mv.Z*spd)
        end
    end)
end

