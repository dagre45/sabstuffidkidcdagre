-- CONFIG SAVE/LOAD
--------------------------------------------------------------
local CONFIG_FILE = "Raider_v8_Config.json"

local function saveConfig()
    pcall(function()
        if not writefile then return end
        local data = {}
        for k,v in pairs(S) do
            if type(v) ~= "function" and k ~= "WebhookURL" then data[k] = v end
        end
        writefile(CONFIG_FILE, HttpService:JSONEncode(data))
    end)
end

local function loadConfig()
    pcall(function()
        if not isfile or not isfile(CONFIG_FILE) then return end
        local data = HttpService:JSONDecode(readfile(CONFIG_FILE))
        for k,v in pairs(data) do if S[k] ~= nil then S[k] = v end end
    end)
end
