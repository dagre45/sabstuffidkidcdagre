-- MAIN HEARTBEAT (single connection)
--------------------------------------------------------------
Run.Heartbeat:Connect(function()
    local h = getHRP()
    local hum2 = getHum()
    if not h or not hum2 then return end

    -- Speed display
    pcall(function() spdLbl.Text = math.floor(h.AssemblyLinearVelocity.Magnitude).." sp" end)

    -- Speed (AssemblyLinearVelocity method - switches to carry speed when holding brainrot)
    if S.Speed then
        local md = hum2.MoveDirection
        if md.Magnitude > 0 then
            local spd = S.TargetSpeed
            if carryingBrainrot or isStealing then spd = S.StealSpeed end
            h.AssemblyLinearVelocity = Vector3.new(md.X*spd, h.AssemblyLinearVelocity.Y, md.Z*spd)
        end
    end

    -- Noclip
    if S.Noclip and Char then
        for _,p in pairs(Char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
    end

    -- Galaxy Mode force update
    if S.GalaxyMode and galaxyVF then
        pcall(function()
            local c=me.Character if not c then return end
            local mass=0
            for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then mass=mass+p:GetMass() end end
            local tg=196.2*(S.GalaxyGravity/100)
            galaxyVF.Force = Vector3.new(0, mass*(196.2-tg)*0.95, 0)
            -- Mini hops when holding space
            if galaxySpaceHeld then
                local rp=c:FindFirstChild("HumanoidRootPart")
                local hum3=c:FindFirstChildOfClass("Humanoid")
                if rp and hum3 and hum3.FloorMaterial==Enum.Material.Air then
                    rp.AssemblyLinearVelocity=Vector3.new(rp.AssemblyLinearVelocity.X,S.HopPower,rp.AssemblyLinearVelocity.Z)
                end
            end
        end)
    end

    -- Ragdoll TP detection (from Plex Hub)
    if S.RagdollTPLeft or S.RagdollTPRight then
        local st = hum2:GetState()
        local isRag = st==Enum.HumanoidStateType.Physics or st==Enum.HumanoidStateType.Ragdoll or st==Enum.HumanoidStateType.FallingDown
        if not isRag then hasRecovered=true end
        if not tpBusy and hasRecovered and isRag then
            if S.RagdollTPLeft then duelTPSequence("Left")
            elseif S.RagdollTPRight then duelTPSequence("Right") end
        end
    end

    -- Bat aimbot (from Cherry Hub lock)
    if S.BatLock then
        local closest, closestD = nil, 999
        for _,p in pairs(Players:GetPlayers()) do
            if p~=me and p.Character then
                local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso") or p.Character:FindFirstChild("HumanoidRootPart")
                local pHum = p.Character:FindFirstChild("Humanoid")
                if torso and pHum and pHum.Health>0 then
                    local d=(torso.Position-h.Position).Magnitude
                    if d<closestD then closestD=d closest={hrp=p.Character:FindFirstChild("HumanoidRootPart"),torso=torso} end
                end
            end
        end
        if closest and closest.torso then
            local dir = closest.torso.Position - h.Position
            if dir.Magnitude > 1.5 then
                local u = dir.Unit
                h.AssemblyLinearVelocity = Vector3.new(u.X*S.LockSpeed, u.Y*S.LockSpeed, u.Z*S.LockSpeed)
            else
                h.AssemblyLinearVelocity = closest.hrp and closest.hrp.AssemblyLinearVelocity or Vector3.zero
            end
        end
    end

    -- Auto swing
    if S.AutoSwing then
        pcall(function()
            local tool = Char:FindFirstChildWhichIsA("Tool")
            if tool then tool:Activate() end
        end)
    end
end)

