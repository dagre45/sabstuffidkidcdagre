        if d<bestD then bestD=d best=animal end
    end
    return best
end

-- REAL STEAL EXECUTOR (from UGC - fires hold callbacks, waits 1.3s, TPs at 73%, fires trigger)
local function executeStealWithTP(sequence)
    if isStealing then return end
    local animal = getNearestAnimal()
    if not animal then Ntf("No animals nearby") return end
    local prompt = findAnimalPrompt(animal)
    if not prompt then
        -- Fallback: fireproximityprompt
        Ntf("Stealing "..animal.slot.."...")
        local h=getHRP()
        if h then
            equipCarpet() task.wait(0.07)
            h.CFrame = CFrame.new(animal.worldPosition + Vector3.new(0,2,0))
            task.wait(0.2)
            -- Try to find any prompt near the podium
            pcall(function()
                local plot=WS.Plots:FindFirstChild(animal.plot)
                local podium=plot and plot.AnimalPodiums:FindFirstChild(animal.slot)
                if podium then
                    local pp=podium:FindFirstChildWhichIsA("ProximityPrompt",true)
                    if pp then sfp(pp) end
                end
            end)
        end
        return
    end

    buildStealCallbacks(prompt)
    local data = InternalStealCache[prompt]
    if not data or not data.ready then return end

    data.ready = false
    isStealing = true

    task.spawn(function()
        equipCarpet()
        task.wait(0.07)

        -- Fire hold callbacks to start steal
        for _,fn in ipairs(data.holdCallbacks) do pcall(task.spawn, fn) end

        local startTime = tick()
        local tpDone = false

        while tick()-startTime < 1.3 do
            local progress = (tick()-startTime)/1.3

            -- At 73% progress, TP away
            if progress >= 0.73 and not tpDone and sequence then
                tpDone = true
                local h=getHRP()
                if h then
                    h.CFrame = sequence[1]
                    task.wait(0.1)
                    h.CFrame = sequence[2]
                    task.wait(0.2)
                    -- Return to nearest safe pos
                    local d1=(h.Position-RETURN_POS1).Magnitude
                    local d2=(h.Position-RETURN_POS2).Magnitude
                    h.CFrame = CFrame.new(d1<d2 and RETURN_POS1 or RETURN_POS2)
                end
            end
            task.wait()
        end

        -- Fire trigger callbacks to complete steal
        for _,fn in ipairs(data.triggerCallbacks) do pcall(task.spawn, fn) end
        task.wait(0.2)
        data.ready = true
        isStealing = false
        Ntf("Stolen from "..animal.plot)
    end)
end

