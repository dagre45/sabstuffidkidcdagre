-- FIXED UTILITY FUNCTIONS
--------------------------------------------------------------
local U = {}

function U.CancelTask(name)
    if Tasks[name] then
        task.cancel(Tasks[name])
        Tasks[name] = nil
    end
end

function U.FindRemote(partial)
    for _, obj in pairs(RS:GetDescendants()) do
        if (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) and
            string.find(string.lower(obj.Name), string.lower(partial)) then
            return obj
        end
    end
end

function U.Fire(r, ...)
    if not r then return end
    pcall(function()
        if r:IsA("RemoteEvent") then r:FireServer(...)
        else r:InvokeServer(...) end
    end)
end

function U.TP(cf)
    if not HRP then return end
    if S.StableTP then
        pcall(function()
            local bv = Instance.new("BodyVelocity", HRP)
            bv.Velocity = Vector3.zero
            bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
            HRP.CFrame = cf
            task.wait(0.15)
            bv:Destroy()
        end)
    else
        HRP.CFrame = cf
    end
end

-- OPTIMIZED: Cache brainrots with debounce
local BrainrotCache = {}
local CacheTime = 0
function U.GetBrainrots()
    local now = tick()
    if now - CacheTime > 0.5 then  -- Update every 0.5s
        BrainrotCache = {}
        for _, obj in pairs(WS:GetDescendants()) do
            if obj:IsA("Model") and obj ~= Char then
                local gen = obj:GetAttribute("Gen") or obj:GetAttribute("Generation")
                local val = obj:GetAttribute("Value") or obj:GetAttribute("Price")
                if not gen then
                    local g = obj:FindFirstChild("Gen") or obj:FindFirstChild("Generation")
                    if g and g:IsA("ValueBase") then gen = tonumber(g.Value) end
                end
                if not val then
                    local v = obj:FindFirstChild("Value") or obj:FindFirstChild("Price")
                    if v and v:IsA("ValueBase") then val = tonumber(v.Value) end
                end
                if gen or val or string.find(string.lower(obj.Name), "brainrot") or string.find(string.lower(obj.Name), "rot") then
                    local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                    if part then
                        table.insert(BrainrotCache, {
                            Model = obj, Name = obj.Name,
                            Gen = tonumber(gen) or 0, Value = tonumber(val) or 0,
                            Position = part.Position,
                        })
                    end
                end
            end
        end
        CacheTime = now
    end
    return BrainrotCache
end

function U.ByGen(t) table.sort(t, function(a, b) return a.Gen > b.Gen end) return t[1] end
function U.ByVal(t) table.sort(t, function(a, b) return a.Value > b.Value end) return t[1] end
function U.ByDist(t)
    if not HRP then return t[1] end
    local p = HRP.Position
    table.sort(t, function(a, b) return (a.Position - p).Magnitude < (b.Position - p).Magnitude end)
    return t[1]
end

function U.Filter(list)
    local out = {}
    for _, b in ipairs(list) do
        local ok = b.Gen >= S.MinGenTP
        if ok and #S.MutFilter > 0 then
            local m = tostring(b.Model:GetAttribute("Mutation") or "")
            local found = false
            for _, f in ipairs(S.MutFilter) do
                if string.find(string.lower(m), string.lower(f)) then found = true break end
            end
            if not found then ok = false end
        end
        if ok then table.insert(out, b) end
    end
    return out
end

-- FIXED ESP MANAGEMENT
function U.ClearESP()
    for target, data in pairs(ESPData) do
        pcall(function()
            if data.B and data.B.Parent then data.B:Destroy() end
            if data.H and data.H.Parent then data.H:Destroy() end
        end)
    end
    ESPData = {}
end

function U.UpdateESP(target, color, label)
    local data = ESPData[target]
    if data then
        data.B.txt.Text = label  -- Update text instead of recreating
        data.H.FillColor = color
        data.H.OutlineColor = color
    else
        -- Create new ESP
        local part = nil
        if target:IsA("Model") then part = target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")
        elseif target:IsA("BasePart") then part = target end
        if not part then return nil end

        local bb = Instance.new("BillboardGui")
        bb.Name = "ESP"
        bb.Adornee = part
        bb.Size = UDim2.new(0, 200, 0, 40)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop = true
        pcall(function() bb.Parent = game:GetService("CoreGui") end)
        if not bb.Parent then bb.Parent = ScreenGui end

        local txt = Instance.new("TextLabel", bb)
        txt.Name = "txt"
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.TextColor3 = color
        txt.TextStrokeTransparency = 0.3
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 13
        txt.Text = label

        local hl = Instance.new("Highlight", target)
        hl.Name = "ESPH"
        hl.FillColor = color
        hl.FillTransparency = 0.7
        hl.OutlineColor = color
        hl.OutlineTransparency = 0.3

        ESPData[target] = {B = bb, H = hl}
    end
end

