local function removeSpin()
    if spinPart then spinPart:Destroy() spinPart=nil end
    pcall(function()
        local h=getHRP() if h then local s=h:FindFirstChild("SpinBV") if s then s:Destroy() end end
    end)
end

-- BAT EQUIP (proper - checks all slap tiers from Ocean Hub)
local function equipBat()
    pcall(function()
        local c=me.Character if not c then return end
        local bp=me:FindFirstChildOfClass("Backpack")
        for _,ch in ipairs(c:GetChildren()) do
            if ch:IsA("Tool") and (ch.Name:lower():find("bat") or ch.Name:lower():find("slap")) then return end
        end
        if bp then
            for i=#SlapList,1,-1 do
                local t=bp:FindFirstChild(SlapList[i])
                if t and Hum then Hum:EquipTool(t) return end
            end
            for _,ch in ipairs(bp:GetChildren()) do
                if ch:IsA("Tool") and (ch.Name:lower():find("bat") or ch.Name:lower():find("slap")) then
                    if Hum then Hum:EquipTool(ch) end return
                end
            end
        end
    end)
end

-- IMPROVED FLOAT (Raycast ground detection from K7/autoduel)
local floatConn = nil
local function startFloat()
    if floatConn then floatConn:Disconnect() end
    floatConn = Run.Heartbeat:Connect(function()
        if not S.Float then floatConn:Disconnect() floatConn=nil return end
        local h=getHRP() if not h then return end
        local params = RaycastParams.new()
        params.FilterDescendantsInstances = {me.Character}
        params.FilterType = Enum.RaycastFilterType.Exclude
        local result = WS:Raycast(h.Position, Vector3.new(0,-500,0), params)
        local groundY = result and result.Position.Y or (h.Position.Y - S.FloatHeight)
        local targetY = groundY + S.FloatHeight
        local diff = targetY - h.Position.Y
        if math.abs(diff) > 0.1 then
            local vy = math.clamp(diff*6, -30, 30)
            h.AssemblyLinearVelocity = Vector3.new(h.AssemblyLinearVelocity.X, vy, h.AssemblyLinearVelocity.Z)
        else
            h.AssemblyLinearVelocity = Vector3.new(h.AssemblyLinearVelocity.X, 0, h.AssemblyLinearVelocity.Z)
        end
    end)
