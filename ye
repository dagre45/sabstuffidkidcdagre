-- Replace all toggle callbacks with this pattern:
local function CreateStealLoop(name, selectorFunc)
    return function(v)
        S[name] = v
        U.CancelTask(name)
        if v then
            Tasks[name] = task.spawn(function()
                while S[name] do
                    local list = U.Filter(U.GetBrainrots())
                    if #list > 0 then
                        local target = selectorFunc(list)
                        if target then DoSteal(target) end
                    end
                    task.wait(S.StealCooldown + 0.5)
                end
            end)
        end
    end
end

