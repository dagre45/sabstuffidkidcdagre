-- Game data modules (for real animal names)
local Sync, AnimalsData, AnimalsShared, NumberUtils
pcall(function()
    local Pkgs = RS:WaitForChild("Packages",5)
    local Datas = RS:WaitForChild("Datas",5)
    local Shared = RS:WaitForChild("Shared",5)
    local Utils2 = RS:WaitForChild("Utils",5)
    if Pkgs then Sync = require(Pkgs:WaitForChild("Synchronizer",3)) end
    if Datas then AnimalsData = require(Datas:WaitForChild("Animals",3)) end
    if Shared then AnimalsShared = require(Shared:WaitForChild("Animals",3)) end
    if Utils2 then NumberUtils = require(Utils2:WaitForChild("NumberUtils",3)) end
end)

local function scanPlots()
    table.clear(allAnimalsCache)
    pcall(function()
        local plots = WS:FindFirstChild("Plots")
        if not plots then return end
        for _,plot in ipairs(plots:GetChildren()) do
            if not isMyBase(plot.Name) then

            -- METHOD 1: Use Synchronizer (gets real names + gen values)
            if Sync then
                pcall(function()
                    local channel = Sync:Get(plot.Name)
                    if not channel then return end
                    local animalList = channel:Get("AnimalList")
                    if not animalList then return end
                    local owner = channel:Get("Owner")
                    local ownerName = owner and owner.Name or "?"

                    for slot, aData in pairs(animalList) do
                        if type(aData) == "table" then
                            local animalName = aData.Index
                            local displayName = animalName
                            local genValue = 0
                            local genText = "?"
                            local rarity = "?"
                            local mutation = aData.Mutation or "None"

                            if AnimalsData and AnimalsData[animalName] then
                                displayName = AnimalsData[animalName].DisplayName or animalName
                                rarity = AnimalsData[animalName].Rarity or "?"
                            end
                            if AnimalsShared then
                                pcall(function()
                                    genValue = AnimalsShared:GetGeneration(animalName, aData.Mutation, aData.Traits, nil)
                                end)
                            end
                            if NumberUtils and genValue > 0 then
                                pcall(function() genText = "$"..NumberUtils:ToString(genValue).."/s" end)
                            else
                                genText = "$"..tostring(genValue)
                            end

                            -- Get world position from podium
                            local worldPos = Vector3.zero
                            local podiums = plot:FindFirstChild("AnimalPodiums")
                            if podiums then
                                local podium = podiums:FindFirstChild(tostring(slot))
                                if podium then worldPos = podium:GetPivot().Position end
                            end

                            table.insert(allAnimalsCache, {
                                name = displayName,
                                genText = genText,
                                genValue = genValue,
                                rarity = rarity,
                                mutation = mutation,
                                owner = ownerName,
                                plot = plot.Name,
                                slot = tostring(slot),
                                uid = plot.Name.."_"..tostring(slot),
                                worldPosition = worldPos,
                            })
                        end
                    end
                end)
            else
                -- METHOD 2: Fallback - scan podium models directly
                local podiums = plot:FindFirstChild("AnimalPodiums")
                if podiums then
                    for _,podium in ipairs(podiums:GetChildren()) do
                        if podium:IsA("Model") and podium:FindFirstChild("Base") then
                            -- Try to get name from any TextLabel inside the podium
                            local animalName = "Unknown"
                            local genText = "?"
                            for _,desc in pairs(podium:GetDescendants()) do
                                if desc:IsA("TextLabel") and desc.Text ~= "" and not string.find(desc.Text,"Steal") then
                                    if #desc.Text < 30 then animalName = desc.Text break end
                                end
                            end
                            table.insert(allAnimalsCache, {
                                name = animalName,
                                genText = genText,
                                genValue = 0,
                                rarity = "?",
                                mutation = "None",
                                owner = "?",
                                plot = plot.Name,
                                slot = podium.Name,
                                uid = plot.Name.."_"..podium.Name,
                                worldPosition = podium:GetPivot().Position,
                            })
                        end
                    end
                end
            end
            end -- if not isMyBase
        end
    end)
end

