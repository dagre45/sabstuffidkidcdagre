-- UNWALK: Stop all animations (from K7)
local unwalkConn
local function enableUnwalk()
    if unwalkConn then unwalkConn:Disconnect() end
    unwalkConn = Run.Heartbeat:Connect(function()
        if not S.Unwalk then unwalkConn:Disconnect() unwalkConn=nil return end
        pcall(function()
            local c=me.Character if not c then return end
            local h=c:FindFirstChildOfClass("Humanoid") if not h then return end
            local a=h:FindFirstChildOfClass("Animator") if not a then return end
            for _,t in ipairs(a:GetPlayingAnimationTracks()) do t:Stop(0) end
        end)
    end)
end

-- ANTI-RAGDOLL (from Plex/K7)
local antiRagConn
local function enableAntiRag()
    if antiRagConn then antiRagConn:Disconnect() end
    antiRagConn = Run.Heartbeat:Connect(function()
        if not S.AntiRagdoll then antiRagConn:Disconnect() antiRagConn=nil return end
        pcall(function()
            local c=me.Character if not c then return end
            local h=c:FindFirstChildOfClass("Humanoid") if not h then return end
            local st=h:GetState()
            if st==Enum.HumanoidStateType.Ragdoll or st==Enum.HumanoidStateType.FallingDown or st==Enum.HumanoidStateType.Physics then
                h:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            for _,o in pairs(c:GetDescendants()) do
                if o:IsA("BallSocketConstraint") then o.Enabled=false end
            end
        end)
    end)
end

-- SPIN (from Cherry Hub)
local spinPart
local function applySpin()
    pcall(function()
        local c=me.Character if not c then return end
        local h=c:FindFirstChild("HumanoidRootPart") if not h then return end
        if spinPart then spinPart:Destroy() end
        spinPart = Instance.new("BodyAngularVelocity",h)
        spinPart.Name = "SpinBV"
        spinPart.AngularVelocity = Vector3.new(0, S.SpinSpeed, 0)
        spinPart.MaxTorque = Vector3.new(0, math.huge, 0)
