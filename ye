-- FIXED STEAL ENGINE WITH COOLDOWN
--------------------------------------------------------------
local function DoSteal(b)
    local now = tick()
    if now - LastSteal < S.StealCooldown then return false end
    LastSteal = now
    
    if not b or not b.Model or not b.Model.Parent or not HRP then return false end

    if S.InvisibleSteal then U.SetInvis(true) end
    local oSpd = Hum and Hum.WalkSpeed or 16
    if S.StealSpeedBoost and Hum then Hum.WalkSpeed = oSpd * S.StealSpeedMulti end
    if S.DisableStealAnim and Hum then
        pcall(function() for _, t in pairs(Hum:GetPlayingAnimationTracks()) do t:Stop() end end)
    end

    if S.AutoUnlockDoor then
        local dr = U.FindRemote("door") or U.FindRemote("unlock")
        if dr then U.Fire(dr) end
    end

    local tPos = b.Position
    if S.PredictiveSteal then
        pcall(function()
            local p = b.Model.PrimaryPart or b.Model:FindFirstChildWhichIsA("BasePart")
            if p then
                local v = p.AssemblyLinearVelocity or p.Velocity
                if v then tPos = p.Position + v * 0.3 end
            end
        end)
    end

    U.TP(CFrame.new(tPos + Vector3.new(0, 2, 0)))
    task.wait(0.15)

    local sr = U.FindRemote("steal") or U.FindRemote("grab") or U.FindRemote("take") or U.FindRemote("collect")
    if sr then U.Fire(sr, b.Model) U.Fire(sr, b.Name) end

    pcall(function()
        local p = b.Model.PrimaryPart or b.Model:FindFirstChildWhichIsA("BasePart")
        if p then safeFireTouch(HRP, p, 0) task.wait(0.1) safeFireTouch(HRP, p, 1) end
    end)
    pcall(function()
        local cd = b.Model:FindFirstChildWhichIsA("ClickDetector", true)
        if cd then safeFireClick(cd) end
    end)
    pcall(function()
        local pp = b.Model:FindFirstChildWhichIsA("ProximityPrompt", true)
        if pp then safeFirePrompt(pp) end
    end)

    task.wait(0.25)
    if S.InvisibleSteal then U.SetInvis(false) end
    if S.StealSpeedBoost and Hum then Hum.WalkSpeed = oSpd end
    if S.InstantClone then local r = U.FindRemote("clone") if r then U.Fire(r) end end
    if S.AutoKickAfterSteal then task.wait(0.3) Plr:Kick("Auto-kick") end

    UI.Notify("Stolen: " .. b.Name .. " | Gen " .. b.Gen, 3)
    return true
end

